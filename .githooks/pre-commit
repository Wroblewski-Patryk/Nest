#!/usr/bin/env sh
set -eu

if [ "${SKIP_LOCAL_GATES:-0}" = "1" ]; then
  echo "[pre-commit] SKIP_LOCAL_GATES=1 -> skipping local quality gates"
  exit 0
fi

echo "[pre-commit] running Nest quality gates"

if [ -f "apps/api/artisan" ]; then
  (
    cd apps/api
    php artisan test --testsuite=Unit --env=testing
  )
fi

if [ -f "apps/web/package.json" ]; then
  (
    cd apps/web
    pnpm lint
    pnpm exec tsc --noEmit
  )
fi

if [ -f "apps/mobile/package.json" ]; then
  (
    cd apps/mobile
    pnpm exec tsc --noEmit
  )
fi

echo "[pre-commit] quality gates passed"
